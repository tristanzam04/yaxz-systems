# Ollama (IA local, gratis)
# Para desarrollo local con Ollama corriendo: deja como está
# Para producción: apunta a un servidor Ollama público o usa Ollama Cloud
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Firebase (para auth y rate limit en producción)
# Para desarrollo sin Firebase, deja estos vacíos (modo dev con "Bearer dev:email@x.com")
FIREBASE_CREDENTIALS_PATH=
FIREBASE_PROJECT_ID=
FIREBASE_API_KEY=

# Puerto
PORT=8000
